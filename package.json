{
  "name": "skir-laravel-data-generator",
  "version": "0.2.0",
  "description": "Skir code generator for Spatie Laravel Data objects.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Maxim Kerstens",
    "email": "maxim.kerstens@gmail.com"
  },
  "homepage": "https://github.com/php-skir/skir-laravel-data-generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/php-skir/skir-laravel-data-generator.git"
  },
  "bugs": {
    "url": "https://github.com/php-skir/skir-laravel-data-generator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "laravel-data",
    "php",
    "rpc",
    "skir",
    "skir-generator"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "skir-laravel-data-generator": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run --cache .npm-cache",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json"
  },
  "dependencies": {
    "@php-skir/generator-core": "^0.1.0",
    "jsonc-parser": "^3.3.1",
    "skir-internal": "^0.2.21",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "skir": "^1.2.19",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
